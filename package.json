{
  "name": "nft-marketplace-v2",
  "version": "1.0.0",
  "description": "A Viem-powered NFT marketplace with Hardhat contracts and a React frontend.",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "test": "hardhat test",
    "deploy": "hardhat run --network localhost scripts/deploy.ts",
    "demo": "hardhat run scripts/demo-marketplace.ts",
    "node": "hardhat node",
    "dev": "hardhat compile && vite --host 0.0.0.0",
    "build": "hardhat compile && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.4",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.4.3",
    "typescript": "~5.8.0",
    "viem": "^2.48.8",
    "vite": "^7.2.7"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.561.0",
    "motion": "^12.38.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.5.0"
  }
